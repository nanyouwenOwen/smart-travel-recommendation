{
  "name": "travel-assistant-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "type-check": "vue-tsc -b",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"e2e/**/*.ts\" \"*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"e2e/**/*.ts\" \"*.{ts,js,json}\"",
    "lint": "eslint src e2e *.ts",
    "check": "npm run format:check && npm run lint && npm run type-check && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.55.1",
    "@tsconfig/node24": "24.0.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "24.10.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "0.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "msw": "^2.10.5",
    "prettier": "^3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "7.3.6",
    "vitest": "^3.2.6",
    "vue-tsc": "3.2.2"
  }
}
